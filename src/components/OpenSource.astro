---
import OrgContributions from './islands/OrgContributions.svelte';
import { manualPatches } from '../lib/projects.ts';
---

<section id="open-source" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="grid md:grid-cols-[0.4fr_1.6fr] gap-10 md:gap-20">
      <div class="reveal">
        <span class="label">
          [ 06 · open source ]
        </span>
      </div>

      <div>
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-[-0.01em] leading-[1.1] reveal">
          Projects I send <span class="text-[var(--color-ink-dim)]">patches to.</span>
        </h2>

        <div class="mt-14">
          <OrgContributions manualPatches={manualPatches} client:visible />
        </div>
      </div>
    </div>
  </div>
</section>
