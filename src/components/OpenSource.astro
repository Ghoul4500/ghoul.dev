---
import { openSource } from '../lib/projects.ts';
import LiveCount from './islands/LiveCount.svelte';

const fieldFor = (org: string): 'asus_linux_mrs' | 'ogc_prs' | null =>
  /asus/i.test(org) ? 'asus_linux_mrs' :
  /gaming/i.test(org) ? 'ogc_prs' :
  null;
---

<section id="open-source" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="grid md:grid-cols-[0.4fr_1.6fr] gap-10 md:gap-20">
      <div class="reveal">
        <span class="label">
          [ 06 · open source ]
        </span>
      </div>

      <div>
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-[-0.01em] leading-[1.1] reveal">
          Projects I send <span class="text-[var(--color-ink-dim)]">patches to.</span>
        </h2>

        <div class="mt-14 columns-1 md:columns-2 gap-6">
          {openSource.map((org) => {
            const field = fieldFor(org.org);
            return (
              <a
                href={org.url}
                target="_blank"
                rel="noopener noreferrer"
                data-cursor="view"
                class="reveal mb-6 break-inside-avoid group relative overflow-hidden rounded-2xl border border-white/[0.06] hover:border-white/20 transition-colors bg-white/[0.015] p-7 md:p-9 ring-line block"
              >
                <div class="flex items-start justify-between">
                  <div>
                    <h3 class="font-display text-xl md:text-2xl font-semibold tracking-[-0.01em]">
                      {org.org}
                    </h3>
                    <div class="mt-1 label normal-case tracking-wider text-[var(--color-ink-dim)]">
                      {org.role}
                    </div>
                  </div>
                  <div class="text-right">
                    <div class="font-display text-4xl md:text-5xl font-semibold tracking-[-0.02em] text-[var(--color-acid)]">
                      {field ? (
                        <LiveCount field={field} fallback={org.prs} client:visible />
                      ) : org.prs}
                    </div>
                    <div class="label mt-0.5">
                      merged
                    </div>
                  </div>
                </div>
                <ul class="mt-6 space-y-2">
                  {org.notable.map((n) => (
                    <li class="flex gap-3 font-body text-[14px] text-[var(--color-ink-dim)] leading-relaxed">
                      <span class="mt-[0.55em] h-px w-3 flex-none bg-[var(--color-ink-faint)]/60"></span>
                      <span>{n}</span>
                    </li>
                  ))}
                </ul>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</section>
