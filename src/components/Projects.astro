---
import { projects } from '../lib/projects.ts';
import ProjectCard from './islands/ProjectCard.svelte';

const highlight = projects.find((p) => p.highlight);
const rest = projects.filter((p) => p !== highlight);
const baseIdx = highlight ? 1 : 0;
---

<section id="work" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="flex items-end justify-between gap-6 reveal">
      <div>
        <span class="label">
          [ 05 · personal / oss ]
        </span>
        <h2 class="mt-4 font-display text-4xl md:text-6xl font-semibold tracking-[-0.015em] leading-[1.05]">
          Side projects & <span class="text-[var(--color-ink-dim)]">open source.</span>
        </h2>
      </div>
      <a
        href="https://github.com/Ghoul4500"
        target="_blank"
        rel="noopener noreferrer"
        data-cursor="visit"
        class="hidden md:inline-flex items-center gap-2 label hover:text-[var(--color-acid)] transition-colors whitespace-nowrap"
      >
        all on github
        <svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M2 10 L10 2 M4 2 H10 V8"/>
        </svg>
      </a>
    </div>

    {highlight && (
      <div class="mt-14 md:mt-20 reveal">
        <ProjectCard project={highlight} index={0} client:visible />
      </div>
    )}

    <div class={`columns-1 md:columns-2 gap-5 md:gap-6 ${highlight ? 'mt-5 md:mt-6' : 'mt-14 md:mt-20'}`}>
      {rest.map((p, i) => (
        <div class="reveal mb-5 md:mb-6 break-inside-avoid">
          <ProjectCard project={p} index={i + baseIdx} client:visible />
        </div>
      ))}
    </div>
  </div>
</section>
