---
import type { ComponentState } from '../../lib/status/derive.ts';
import { SEVERITY_LABEL, HISTORY_DAYS } from '../../lib/status/derive.ts';

interface Props {
  components: ComponentState[];
}

const { components } = Astro.props;

function uptimePct(history: ComponentState['history']): string {
  const total = history.length || 1;
  const ok = history.filter((h) => h.severity === 'operational').length;
  return ((ok / total) * 100).toFixed(2);
}
---
<div class="status-grid">
  {components.map((c) => (
    <div class={`status-cell sev-${c.severity}`}>
      <div class="status-cell__header">
        <span class="status-cell__name">{c.label}</span>
        <span class="status-cell__dot" aria-hidden="true"></span>
      </div>
      <div class="status-cell__sev">{SEVERITY_LABEL[c.severity]}</div>
      <div class="status-cell__desc">{c.description}</div>

      <div class="status-cell__history" role="img" aria-label={`${c.label} status, last ${HISTORY_DAYS} days`}>
        {c.history.map((d) => (
          <span
            class={`uptime-bar sev-bar-${d.severity}`}
            title={`${d.date} — ${SEVERITY_LABEL[d.severity]}`}
          ></span>
        ))}
      </div>
      <div class="status-cell__history-foot label">
        <span>{HISTORY_DAYS}d ago</span>
        <span class="status-cell__uptime">{uptimePct(c.history)}% uptime</span>
        <span>today</span>
      </div>
    </div>
  ))}
</div>

<style>
  .status-grid {
    display: grid;
    grid-template-columns: repeat(1, minmax(0, 1fr));
    gap: 10px;
  }
  @media (min-width: 640px) {
    .status-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (min-width: 1024px) {
    .status-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; }
  }
  .status-cell {
    position: relative;
    padding: 14px 16px;
    border: 1px solid color-mix(in srgb, var(--color-ink) 9%, transparent);
    background: color-mix(in srgb, var(--color-bg-elev) 65%, transparent);
    backdrop-filter: blur(4px);
    border-left-width: 3px;
    transition: background 200ms ease;
  }
  .status-cell__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .status-cell__name {
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-ink);
    font-weight: 500;
  }
  .status-cell__dot {
    width: 8px;
    height: 8px;
    border-radius: 999px;
    flex-shrink: 0;
  }
  .status-cell__sev {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-top: 8px;
  }
  .status-cell__desc {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-ink-faint);
    margin-top: 6px;
    line-height: 1.45;
  }
  .sev-operational    { border-left-color: var(--color-acid); }
  .sev-operational    .status-cell__dot { background: var(--color-acid); box-shadow: 0 0 8px var(--color-acid); }
  .sev-operational    .status-cell__sev { color: var(--color-acid); }

  .sev-degraded       { border-left-color: #d4b34d; }
  .sev-degraded       .status-cell__dot { background: #d4b34d; box-shadow: 0 0 8px color-mix(in srgb, #d4b34d 60%, transparent); }
  .sev-degraded       .status-cell__sev { color: #d4b34d; }

  .sev-partial_outage { border-left-color: var(--color-ember); }
  .sev-partial_outage .status-cell__dot { background: var(--color-ember); box-shadow: 0 0 8px color-mix(in srgb, var(--color-ember) 60%, transparent); }
  .sev-partial_outage .status-cell__sev { color: var(--color-ember); }

  .sev-major_outage   { border-left-color: #ff5252; }
  .sev-major_outage   .status-cell__dot { background: #ff5252; box-shadow: 0 0 10px #ff5252; }
  .sev-major_outage   .status-cell__sev { color: #ff7878; }

  .sev-presumed_dead  { border-left-color: #b03030; }
  .sev-presumed_dead  .status-cell__dot { background: #b03030; }
  .sev-presumed_dead  .status-cell__sev { color: #b03030; }

  .status-cell__history {
    display: flex;
    gap: 1px;
    margin-top: 14px;
    height: 26px;
    align-items: stretch;
  }
  .uptime-bar {
    flex: 1 1 0;
    min-width: 0;
    background: color-mix(in srgb, var(--color-acid) 55%, transparent);
    border-radius: 1px;
    transition: transform 120ms ease, filter 120ms ease;
  }
  .uptime-bar:hover {
    transform: scaleY(1.12);
    filter: brightness(1.4);
  }
  .sev-bar-operational    { background: color-mix(in srgb, var(--color-acid) 55%, transparent); }
  .sev-bar-degraded       { background: color-mix(in srgb, #d4b34d 80%, transparent); }
  .sev-bar-partial_outage { background: color-mix(in srgb, var(--color-ember) 85%, transparent); }
  .sev-bar-major_outage   { background: #ff5252; box-shadow: 0 0 4px color-mix(in srgb, #ff5252 60%, transparent); }
  .sev-bar-presumed_dead  { background: #b03030; }

  .status-cell__history-foot {
    display: flex;
    justify-content: space-between;
    margin-top: 6px;
    font-size: 9px !important;
    color: var(--color-ink-faint) !important;
  }
  .status-cell__uptime {
    color: var(--color-ink-dim) !important;
  }
</style>
