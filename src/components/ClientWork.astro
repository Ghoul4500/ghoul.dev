---
import { clients } from '../lib/clients.ts';

const kindLabel: Record<string, string> = {
  government: 'gov',
  product: 'product',
  ai: 'ai',
  mobile: 'mobile',
  aviation: 'aviation',
  security: 'security',
};
---

<section id="clients" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="flex items-end justify-between gap-6 reveal">
      <div>
        <span class="label">
          [ 04 · client work ]
        </span>
        <h2 class="mt-4 font-display text-3xl md:text-5xl font-semibold tracking-[-0.01em] leading-[1.05] text-balance max-w-[28ch]">
          Real work for <span class="text-[var(--color-ink-dim)]">real clients.</span>
        </h2>
        <p class="mt-5 font-body text-[15px] md:text-[16px] text-[var(--color-ink-dim)] max-w-[64ch] font-light">
          Most of this is in private repos, so what's here is just the shape of the work and the stack — nothing internal. Government ministries, product companies, a few AI things.
        </p>
      </div>
    </div>

    <div class="mt-14 md:mt-20 columns-1 md:columns-2 gap-4 md:gap-5">
      {clients.map((c, i) => {
        const accent =
          c.accent === 'ember' ? 'var(--color-ember)' :
          c.accent === 'violet' ? 'var(--color-violet)' :
          c.accent === 'cyan' ? 'var(--color-cyan)' :
          'var(--color-acid)';
        const Tag = c.url ? 'a' : 'div';
        return (
          <div class="reveal mb-4 md:mb-5 break-inside-avoid">
            <Tag
              {...(c.url ? { href: c.url, target: '_blank', rel: 'noopener noreferrer', 'data-cursor': 'view' } : {})}
              class={`group relative block rounded-2xl border border-white/[0.06] ${c.url ? 'hover:border-white/20' : ''} transition-colors bg-white/[0.015] p-6 md:p-7 ring-line`}
              style={`--accent: ${accent}`}
            >
              <div class="flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-faint)] flex items-center gap-2 flex-wrap">
                    <span>#{String(i + 1).padStart(2, '0')}</span>
                    <span>·</span>
                    <span style={`color: ${accent}`}>{kindLabel[c.kind]}</span>
                    <span>·</span>
                    <span>via {c.through}</span>
                  </div>
                  <h3 class="mt-3 font-display text-lg md:text-2xl font-semibold tracking-[-0.01em] leading-[1.15]">
                    <span style={`color: ${accent}`}>&gt;</span> {c.name}
                  </h3>
                </div>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)] whitespace-nowrap pt-1">
                  {c.period}
                </span>
              </div>

              <p class="mt-4 font-body text-[14.5px] leading-[1.65] text-[var(--color-ink-dim)] font-light">
                {c.summary}
              </p>

              {c.notable && c.notable.length > 0 && (
                <ul class="mt-4 space-y-1.5">
                  {c.notable.map((n) => (
                    <li class="flex gap-3 font-body text-[13.5px] text-[var(--color-ink-dim)] leading-relaxed">
                      <span class="mt-[0.6em] h-px w-3 flex-none bg-[var(--color-ink-faint)]/60"></span>
                      <span>{n}</span>
                    </li>
                  ))}
                </ul>
              )}

              <div class="mt-5 flex flex-wrap items-center gap-2">
                {c.stack.map((t) => (
                  <span class="font-mono text-[10px] uppercase tracking-[0.18em] px-2 py-0.5 rounded-md border border-white/10 text-[var(--color-ink)]/80">
                    {t}
                  </span>
                ))}
              </div>

              <div class="mt-5 flex items-center justify-between">
                <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-faint)]">
                  {c.role}
                </span>
                {c.url ? (
                  <span class="inline-flex items-center gap-1.5 font-mono text-[10px] uppercase tracking-[0.22em] transition-opacity group-hover:opacity-100 opacity-70" style={`color: ${accent}`}>
                    open org
                    <svg class="h-2.5 w-2.5 transition-transform group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
                      <path d="M2 10 L10 2 M4 2 H10 V8"/>
                    </svg>
                  </span>
                ) : (
                  <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-faint)]">
                    private
                  </span>
                )}
              </div>
            </Tag>
          </div>
        );
      })}
    </div>
  </div>
</section>
