---
import { education, otherAwards } from '../lib/clients.ts';
---

<section id="education" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="grid md:grid-cols-[0.4fr_1.6fr] gap-10 md:gap-20">
      <div class="reveal">
        <span class="label">
          [ 07 · education ]
        </span>
      </div>

      <div>
        <h2 class="font-display text-3xl md:text-5xl font-semibold tracking-[-0.01em] leading-[1.1] reveal">
          School and <span class="text-[var(--color-ink-dim)]">a few medals.</span>
        </h2>

        <ol class="mt-12 divide-y divide-white/[0.06]">
          {education.map((e) => (
            <li class="reveal py-7">
              <div class="flex items-baseline justify-between gap-4">
                <h3 class="font-display text-base md:text-lg font-semibold tracking-[-0.005em]">
                  {e.qualification}
                </h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-faint)] whitespace-nowrap">
                  {e.period}
                </span>
              </div>
              <div class="mt-1 font-mono text-[12px] text-[var(--color-ink-dim)]">
                {e.school}
                {e.partnerSchool && (
                  <>
                    <span class="text-[var(--color-ink-faint)] mx-1.5">·</span>
                    <span>{e.partnerSchool}</span>
                  </>
                )}
              </div>

              {e.awards && e.awards.length > 0 && (
                <ul class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-1.5">
                  {e.awards.map((a) => (
                    <li class="flex items-baseline gap-2 font-mono text-[12.5px] text-[var(--color-ink)]">
                      <span class="text-[var(--color-acid)] flex-none">✦</span>
                      <span>{a}</span>
                    </li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ol>

        {otherAwards.length > 0 && (
          <div class="reveal mt-10 pt-6 border-t border-white/[0.06]">
            <div class="label mb-4 text-[var(--color-ink-faint)]">— other</div>
            <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2">
              {otherAwards.map((a) => (
                <li class="flex items-baseline justify-between gap-3 font-mono text-[12.5px]">
                  <span class="flex items-baseline gap-2 text-[var(--color-ink)]">
                    <span class="text-[var(--color-acid)] flex-none">✦</span>
                    <span>{a.title}</span>
                  </span>
                  <span class="text-[var(--color-ink-faint)] uppercase tracking-[0.18em] text-[10.5px] whitespace-nowrap">
                    {a.where} · {a.year}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
