---
import { experience } from '../lib/experience.ts';

const current = experience.filter((r) => !r.prior);
const prior = experience.filter((r) => r.prior);
---

<section id="experience" class="relative py-32 md:py-48 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="grid md:grid-cols-[0.4fr_1.6fr] gap-10 md:gap-20">
      <div class="reveal">
        <span class="label">
          [ 03 · where i work ]
        </span>
      </div>

      <div>
        <h2 class="font-display text-4xl md:text-6xl font-semibold tracking-[-0.015em] leading-[1.05] reveal">
          Work & <span class="text-[var(--color-ink-dim)]">affiliations.</span>
        </h2>

        <ol class="mt-16 divide-y divide-white/[0.06]">
          {current.map((role, i) => (
            <li class="reveal py-8 md:py-10 group">
              <div class="grid md:grid-cols-[auto_1fr_auto] gap-4 md:gap-10 items-start">
                <div class="font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-faint)] md:w-44">
                  {role.period}
                  {role.current && (
                    <span class="ml-2 inline-flex items-center gap-1.5 text-[var(--color-acid)] normal-case tracking-normal">
                      <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-acid)] animate-pulse"></span>
                      now
                    </span>
                  )}
                </div>

                <div>
                  <div class="flex items-baseline gap-3 flex-wrap">
                    {role.url ? (
                      <a
                        href={role.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-cursor="visit"
                        class="font-display text-2xl md:text-4xl font-medium tracking-tight hover:text-[var(--color-acid)] transition-colors"
                      >
                        {role.company}
                      </a>
                    ) : (
                      <span class="font-display text-2xl md:text-4xl font-medium tracking-tight">{role.company}</span>
                    )}
                    {role.group && (
                      <span class="font-mono text-[11px] uppercase tracking-[0.2em] text-[var(--color-ink-faint)]">
                        · {role.group}
                      </span>
                    )}
                  </div>
                  <div class="mt-2 font-mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-ink-dim)]">
                    — {role.role}
                  </div>
                  <p class="mt-4 font-body text-[15px] leading-[1.65] text-[var(--color-ink-dim)] max-w-[60ch] font-light">
                    {role.description}
                  </p>
                </div>

                <div class="hidden md:flex justify-end pt-2">
                  <span class="font-mono text-[11px] text-[var(--color-ink-faint)]">
                    {String(i + 1).padStart(2, '0')}
                  </span>
                </div>
              </div>
            </li>
          ))}
        </ol>

        {prior.length > 0 && (
          <div class="mt-20 reveal">
            <div class="flex items-baseline gap-4 mb-8">
              <span class="font-mono text-[10px] uppercase tracking-[0.24em] text-[var(--color-ink-faint)]">
                prior roles
              </span>
              <span class="h-px flex-1 bg-white/[0.06]"></span>
            </div>

            <ol class="grid md:grid-cols-2 gap-4">
              {prior.map((role) => (
                <li class="reveal rounded-2xl border border-white/[0.06] bg-white/[0.015] p-6 md:p-7 ring-line hover:border-white/15 transition-colors">
                  <div class="flex items-baseline justify-between gap-4">
                    {role.url ? (
                      <a
                        href={role.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        data-cursor="visit"
                        class="font-display text-xl md:text-2xl font-semibold tracking-[-0.01em] hover:text-[var(--color-acid)] transition-colors"
                      >
                        {role.company}
                      </a>
                    ) : (
                      <span class="font-display text-xl md:text-2xl font-semibold tracking-[-0.01em]">{role.company}</span>
                    )}
                    <span class="font-mono text-[10px] uppercase tracking-[0.22em] text-[var(--color-ink-faint)]">
                      {role.period}
                    </span>
                  </div>
                  <div class="mt-1 font-mono text-[11px] uppercase tracking-[0.18em] text-[var(--color-ink-dim)]">
                    — {role.role}
                  </div>
                  <p class="mt-3 font-body text-[14px] leading-[1.65] text-[var(--color-ink-dim)] font-light">
                    {role.description}
                  </p>
                </li>
              ))}
            </ol>
          </div>
        )}
      </div>
    </div>
  </div>
</section>
