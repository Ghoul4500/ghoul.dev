---
---
<section id="contact" class="relative py-32 md:py-56 px-6 md:px-10 border-t hairline">
  <div class="mx-auto w-full max-w-[1400px]">
    <div class="flex items-start justify-between gap-6 reveal">
      <span class="label">
        [ 08 · contact ]
      </span>
      <span class="label text-right">
        open to <br/><span class="text-[var(--color-acid)]">new work</span>
      </span>
    </div>

    <h2 class="mt-14 font-display text-4xl md:text-[7rem] font-semibold tracking-[-0.025em] leading-[0.95] reveal">
      <span class="text-[var(--color-acid)]">&gt;</span> Say hi.
      <span class="text-[var(--color-ink-dim)]">Got something to build?</span>
    </h2>

    <div class="mt-14 grid md:grid-cols-[1.3fr_1fr] gap-12 md:gap-24 items-end">
      <div class="reveal">
        <a
          href="mailto:yaseen@ghoul.dev"
          data-cursor="write"
          class="group inline-flex items-center gap-4 font-display text-2xl md:text-4xl font-semibold tracking-[-0.01em]"
        >
          <span class="relative">
            yaseen@ghoul.dev
            <span class="absolute left-0 right-0 -bottom-1 h-[2px] bg-[var(--color-acid)] origin-left scale-x-0 group-hover:scale-x-100 transition-transform duration-500"></span>
          </span>
          <svg class="h-5 w-5 md:h-7 md:w-7 transition-transform duration-500 group-hover:translate-x-1 group-hover:-translate-y-1" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M5 19 L19 5 M8 5 H19 V16"/>
          </svg>
        </a>
        <p class="mt-4 font-body text-base md:text-lg text-[var(--color-ink-dim)] max-w-[48ch] font-light">
          Full-stack gigs, Linux consulting, or an interesting problem. Email me directly. If it's a company-to-company thing, go through Zenryk.
        </p>

        <div class="mt-8 flex flex-wrap gap-4 font-mono text-[13px]">
          <a href="mailto:info@zenryk.com" data-cursor="write" class="inline-flex items-center gap-2 text-[var(--color-ink-dim)] hover:text-[var(--color-ink)] transition-colors">
            <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-acid)]"></span>
            zenryk :: info@zenryk.com
          </a>
        </div>
      </div>

      <div class="reveal grid grid-cols-2 gap-3 md:gap-4 label">
        <a href="https://github.com/Ghoul4500" target="_blank" rel="noopener noreferrer" data-cursor="visit" class="social">github ↗</a>
        <a href="https://gitlab.com/Ghoul4500" target="_blank" rel="noopener noreferrer" data-cursor="visit" class="social">gitlab ↗</a>
        <a href="https://zenryk.com" target="_blank" rel="noopener noreferrer" data-cursor="visit" class="social">zenryk ↗</a>
        <a href="mailto:yaseen@ghoul.dev" data-cursor="write" class="social">email ↗</a>
      </div>
    </div>
  </div>
</section>

<style>
  .social {
    padding: 1.1rem 1.25rem;
    border: 1px solid color-mix(in srgb, white 8%, transparent);
    border-radius: 12px;
    background: color-mix(in srgb, white 2%, transparent);
    transition: border-color .3s, color .3s, background .3s;
  }
  .social:hover {
    border-color: color-mix(in srgb, var(--color-acid) 50%, transparent);
    color: var(--color-acid);
    background: color-mix(in srgb, var(--color-acid) 4%, transparent);
  }
</style>
