---
import ScrambleText from './islands/ScrambleText.svelte';
---

<section id="top" class="relative min-h-[100svh] flex flex-col justify-between pt-28 pb-10 px-6 md:px-10">
  <div class="mx-auto w-full max-w-[1400px] flex-1 flex flex-col justify-center">
    <div class="flex items-center gap-4 label mb-10 reveal">
      <span class="inline-flex items-center gap-2">
        <span class="h-1.5 w-1.5 rounded-full bg-[var(--color-acid)]"></span>
        <span class="text-[var(--color-ink)]">available</span>
        <span class="text-[var(--color-ink-faint)]">/ full-stack engineer</span>
      </span>
      <span class="h-px flex-1 bg-[var(--color-ink-faint)]/40 max-w-[140px]"></span>
      <span>MV · UTC+5</span>
    </div>

    <h1 class="font-display font-semibold leading-[0.98] tracking-[-0.02em] text-[clamp(3rem,10vw,9.5rem)] reveal">
      <span class="block">
        <span class="text-[var(--color-acid)]">&gt;</span>
        <ScrambleText text="ahmed" client:load duration={800} />
      </span>
      <span class="block">
        <span class="text-[var(--color-ink-faint)]">&nbsp;&nbsp;</span>
        <ScrambleText text="yaseen" client:load delay={120} duration={1000} />
        <span class="inline-block w-[0.6em] h-[0.9em] translate-y-[0.1em] bg-[var(--color-acid)] blink ml-2"></span>
      </span>
    </h1>

    <div class="mt-14 grid md:grid-cols-[1.4fr_1fr] gap-10 md:gap-16 items-end reveal">
      <p class="font-body text-lg md:text-2xl leading-[1.45] text-[var(--color-ink)] max-w-[52ch] font-light">
        Backend, frontend, and Linux-adjacent tooling. Most of my commits are TypeScript and PHP these days; Rust when the problem needs it.
      </p>
      <div class="label md:text-right leading-relaxed">
        <div>engineer_at = <span class="text-[var(--color-ink)]">OXIQA</span></div>
        <div class="mt-1">founder_of = <a href="https://zenryk.com" target="_blank" rel="noopener noreferrer" data-cursor="visit" class="text-[var(--color-ink)] hover:text-[var(--color-acid)] transition-colors">Zenryk</a></div>
        <div class="mt-4 text-[var(--color-ink-faint)]">
          upstream :: ogc, caelestia
        </div>
      </div>
    </div>
  </div>

  <div class="mx-auto w-full max-w-[1400px] mt-16 flex items-center justify-between label">
    <span>scroll ↓</span>
    <span>[ 01 / index ]</span>
    <span>© 2026</span>
  </div>

  <div aria-hidden="true" class="absolute left-6 md:left-10 bottom-10 flex flex-col items-start gap-2 pointer-events-none">
    <span class="h-10 w-px bg-gradient-to-b from-[var(--color-acid)] to-transparent"></span>
  </div>
</section>
