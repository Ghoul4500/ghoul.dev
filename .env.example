# GitHub personal access token — read-only, server-side only.
#
# Used by the Hono API at /api/github/stats to produce a more accurate language
# breakdown that includes private repos (OXIQA, MOTCA, Hologo-World, MoHE-HEMS,
# synetecs, etc). The token NEVER leaves the server process; the response payload
# exposes only aggregated stats — no private repo names, URLs, or descriptions.
#
# Minimum scope — fine-grained PAT (preferred):
#   Repository access: All repositories (including orgs you want reflected)
#   Permissions:
#     - Metadata:   Read-only  (required)
#     - Contents:   Read-only  (required for /repos/.../languages on private repos)
#
# Classic PAT alternative:
#   repo  (full control of private repos — broader than needed, use only if you must)
#
# Create at https://github.com/settings/personal-access-tokens
# Copy .env.example → .env and fill in:

GITHUB_TOKEN=

# Status page Telegram bot — both values required for the bot to listen.
#
# 1. Create a separate bot from your existing one (this is for status control
#    only, not for Claude harness comms). Talk to @BotFather, /newbot, copy the
#    HTTP token. Then set the bot's privacy to "off" with /setprivacy if you
#    want it to read non-command messages in groups (optional; DMs always work).
# 2. Get your numeric Telegram user ID — talk to @userinfobot. Only this ID is
#    allowed to issue commands; everyone else is silently ignored.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# Optional: override the GitHub username checked for "presumed dead" commit
# signal. Defaults to Ghoul4500.
# STATUS_GITHUB_USER=Ghoul4500

# Optional: override the directory the status JSON store is written to.
# Defaults to ./data inside the project. Useful when running under a different
# working directory in production.
# STATUS_DATA_DIR=/var/lib/ghoul.dev/status
